<UserControl x:Class="PMS.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32,28">
        <StackPanel>
            <TextBlock Text="{Binding Heading}" Style="{StaticResource HeadingLargeText}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource Card}">
                <TextBlock Text="{Binding Description}" Style="{StaticResource BodyText}"
                           TextWrapping="Wrap" LineHeight="22"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
