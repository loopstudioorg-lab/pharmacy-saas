<UserControl x:Class="PMS.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,28">
        <StackPanel>
            <TextBlock Text="Dashboard" Style="{StaticResource HeadingLargeText}" Margin="0,0,0,4"/>
            <TextBlock Text="Today's overview at a glance. Real numbers appear once medicines, sales and purchases come online in later phases."
                       Style="{StaticResource CaptionText}" Margin="0,0,0,24"/>

            <UniformGrid Columns="3" Rows="2" Margin="0,0,0,24">
                <Border Style="{StaticResource Card}" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="TODAY SALES" Style="{StaticResource CaptionText}"/>
                        <TextBlock Style="{StaticResource KpiNumberText}"
                                   Text="{Binding TodaySales, StringFormat='Rs {0:N0}'}" Margin="0,8,0,0"/>
                        <TextBlock Text="Phase 4 unlocks live sales" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="6,0,6,12">
                    <StackPanel>
                        <TextBlock Text="TODAY PROFIT" Style="{StaticResource CaptionText}"/>
                        <TextBlock Style="{StaticResource KpiNumberText}"
                                   Text="{Binding TodayProfit, StringFormat='Rs {0:N0}'}"
                                   Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="Computed from sales - cost" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="12,0,0,12">
                    <StackPanel>
                        <TextBlock Text="STOCK VALUE" Style="{StaticResource CaptionText}"/>
                        <TextBlock Style="{StaticResource KpiNumberText}"
                                   Text="{Binding StockValue, StringFormat='Rs {0:N0}'}" Margin="0,8,0,0"/>
                        <TextBlock Text="Phase 2 unlocks live stock" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,12,12,0">
                    <StackPanel>
                        <TextBlock Text="LOW STOCK ITEMS" Style="{StaticResource CaptionText}"/>
                        <TextBlock Style="{StaticResource KpiNumberText}"
                                   Text="{Binding LowStockCount}"
                                   Foreground="{StaticResource WarningBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="Below reorder level" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="6,12,6,0">
                    <StackPanel>
                        <TextBlock Text="NEAR EXPIRY ITEMS" Style="{StaticResource CaptionText}"/>
                        <TextBlock Style="{StaticResource KpiNumberText}"
                                   Text="{Binding NearExpiryCount}"
                                   Foreground="{StaticResource DangerBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="Expiring within 60 days" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="12,12,0,0">
                    <StackPanel>
                        <TextBlock Text="LICENSE DAYS LEFT" Style="{StaticResource CaptionText}"/>
                        <TextBlock Style="{StaticResource KpiNumberText}"
                                   Text="{Binding LicenseDaysLeft}"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Tier: " Style="{StaticResource CaptionText}"/>
                            <TextBlock Text="{Binding LicenseTier}" Style="{StaticResource CaptionText}" Margin="2,0,8,0"/>
                            <TextBlock Text="Status: " Style="{StaticResource CaptionText}"/>
                            <TextBlock Text="{Binding LicenseStatus}" Style="{StaticResource CaptionText}" Margin="2,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Welcome to Pharmacy Saas" Style="{StaticResource SubheadingText}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyText}" LineHeight="22">
                        Phase 1 Foundation is live. Setup, login, machine binding, license tracking, audit logs,
                        permissions, modular feature flags and a clean UI shell are wired up. Upcoming phases
                        unlock Medicines, Stock, Purchases, Sales POS, Smart Invoice Import, Reports, Cloud sync
                        and more - one focused phase at a time.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
