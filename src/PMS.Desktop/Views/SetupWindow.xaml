<Window x:Class="PMS.Desktop.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pharmacy Saas - First-Time Setup"
        Style="{StaticResource WindowChromeStyle}"
        Width="900" Height="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel Margin="32,40">
                <TextBlock Text="Pharmacy Saas"
                           FontSize="26" FontWeight="SemiBold"
                           Foreground="White"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Offline-first Pharmacy ERP"
                           FontSize="13"
                           Foreground="#DCE0F5"
                           Margin="0,0,0,28"/>

                <TextBlock Text="WELCOME"
                           FontSize="11" FontWeight="Bold"
                           Foreground="#B9C0E5"
                           Margin="0,16,0,8"/>
                <TextBlock TextWrapping="Wrap"
                           FontSize="13"
                           LineHeight="20"
                           Foreground="#E8EAF6"
                           Text="Set up your pharmacy account and create the owner login. Your pharmacy is bound to this machine and a 30-day free trial begins immediately."/>

                <TextBlock Text="DEMO CREDENTIALS"
                           FontSize="11" FontWeight="Bold"
                           Foreground="#B9C0E5"
                           Margin="0,28,0,8"/>
                <Border Background="#283593" CornerRadius="6" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="Pharmacy Code: PHM-DEMO" Foreground="White" FontFamily="Consolas"/>
                        <TextBlock Text="Setup Code:    123456"  Foreground="White" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="40,32">
            <StackPanel MaxWidth="540" HorizontalAlignment="Stretch">
                <TextBlock Text="Set up your pharmacy"
                           Style="{StaticResource HeadingLargeText}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Phase 1 uses mock activation. Real cloud activation lands in Phase 6."
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,0,28"/>

                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Activation" Style="{StaticResource SubheadingText}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Pharmacy Code" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource PrimaryTextBox}"
                                         Text="{Binding PharmacyCode, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Setup Code" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource PrimaryTextBox}"
                                         Text="{Binding SetupCode, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Pharmacy details" Style="{StaticResource SubheadingText}" Margin="0,0,0,12"/>
                        <TextBlock Text="Pharmacy Name *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource PrimaryTextBox}"
                                 Text="{Binding PharmacyName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Phone" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource PrimaryTextBox}"
                                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource PrimaryTextBox}"
                                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="City" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource PrimaryTextBox}"
                                         Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Address" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource PrimaryTextBox}"
                                         Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FlatCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Owner account" Style="{StaticResource SubheadingText}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Owner Name" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource PrimaryTextBox}"
                                         Text="{Binding OwnerName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Owner Username *" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource PrimaryTextBox}"
                                         Text="{Binding OwnerUsername, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Password *" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="PasswordInput" Style="{StaticResource PrimaryPasswordBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Confirm Password *" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="ConfirmInput" Style="{StaticResource PrimaryPasswordBox}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource CaptionText}"
                           Foreground="{StaticResource DangerBrush}"
                           Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnCancelClick"
                            Margin="0,0,12,0"/>
                    <Button x:Name="CompleteButton"
                            Content="Complete Setup"
                            Style="{StaticResource PrimaryButton}"
                            Click="OnCompleteClick"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
