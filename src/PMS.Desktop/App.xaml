<Application x:Class="PMS.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PMS.Desktop.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme/Colors.xaml"/>
                <ResourceDictionary Source="Theme/Typography.xaml"/>
                <ResourceDictionary Source="Theme/Buttons.xaml"/>
                <ResourceDictionary Source="Theme/Inputs.xaml"/>
                <ResourceDictionary Source="Theme/Cards.xaml"/>
                <ResourceDictionary Source="Theme/Layout.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
